kernels/*.o
kernels/*.ptx
kernels/*.fatbin
kernels/*.cubin
*.a
*.so
*.dylib

# Model weights (too large for git — use LFS or external storage)
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
weights/
checkpoints/
runs/

# Training data & corpus (too large)
corpus/
data/raw/
data/processed/
*.jsonl
*.parquet

# Python artifacts (for tooling scripts only)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Environment
.env
.env.local
*.key
*.pem
secrets/

# Logs and benchmarks output
logs/
*.log
benchmark_results/

# LaTeX build artifacts (paper/)
docs/papers/*.aux
docs/papers/*.bbl
docs/papers/*.blg
docs/papers/*.log
docs/papers/*.out
docs/papers/*.toc
docs/papers/*.synctex.gz
